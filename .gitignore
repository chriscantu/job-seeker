# Generated application materials (per-company outputs)
output/

# Legacy state directory (deprecated — state lives in output/)
memory/

# Personal config files (only .example templates are committed)
integrations/config/*.md
!integrations/config/*.md.example

# Candidate config files (personal — only .example templates are committed)
config/candidate.md
config/search.md

# Personal references — PII (deny by default, allowlist shared files)
/references/*
!/references/email-patterns.md
!/references/skills-master.md
!/references/resume.md

# Outdated files
job-search-system.md

# Dependencies
node_modules/

# Claude Code local session data — track only commands/
.claude/*
!.claude/commands/

# Build/coverage artifacts
default.profraw

# Git worktrees
.worktrees/

# OS files
.DS_Store

# Gmail API credentials (OAuth2 tokens — personal)
credentials/

# Editor config (personal)
.vscode/

# Python virtualenvs
mlx_env/

# MCP server logs
*.log
