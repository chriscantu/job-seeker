# Apple Notes Configuration

# Absolute path to the job-seeker plugin repo on your Mac.
# This is passed to osascript so scripts can be found at runtime.
# No trailing slash.
plugin_root: ~/repos/job-seeker

# Apple Notes folder where the daily digest and state notes are stored.
# This folder will be created automatically if it does not exist.
default_folder: Notes

# iCloud account name as it appears in Apple Notes sidebar.
# Use "iCloud" for standard iCloud accounts.
# Use "On My Mac" for local-only storage (no cross-device sync).
account: iCloud
